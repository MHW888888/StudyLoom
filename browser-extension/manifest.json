{
  "manifest_version": 3,
  "name": "StudyLoom Current Page Export",
  "version": "1.3.0",
  "description": "Export only the user-initiated current page as sanitized source2study browser_capture JSON.",
  "permissions": ["activeTab", "downloads"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Export current page to Source2Study"
  },
  "background": {
    "service_worker": "export-current-page.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
